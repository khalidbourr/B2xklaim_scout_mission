    "explore": {
      "xml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" xmlns:camunda=\"http://camunda.org/schema/1.0/bpmn\" id=\"Definitions_1m2ni7v\" targetNamespace=\"http://bpmn.io/schema/bpmn\" exporter=\"Camunda Modeler\" exporterVersion=\"5.45.0\">\n  <bpmn:process id=\"Explore\" name=\"Explore\" isExecutable=\"true\">\n    <bpmn:startEvent id=\"StartEvent_1\" name=\"start spiral exploration\">\n      <bpmn:outgoing>Flow_1patyjx</bpmn:outgoing>\n    </bpmn:startEvent>\n    <bpmn:sequenceFlow id=\"Flow_1patyjx\" sourceRef=\"StartEvent_1\" targetRef=\"Gateway_0q8a77l\" />\n    <bpmn:parallelGateway id=\"Gateway_072gr8o\">\n      <bpmn:incoming>Flow_087fu4v</bpmn:incoming>\n      <bpmn:outgoing>Flow_1nefhcf</bpmn:outgoing>\n      <bpmn:outgoing>Flow_08rzk0i</bpmn:outgoing>\n    </bpmn:parallelGateway>\n    <bpmn:sequenceFlow id=\"Flow_1nefhcf\" sourceRef=\"Gateway_072gr8o\" targetRef=\"Activity_0q3o3qk\" />\n    <bpmn:scriptTask id=\"Activity_0q3o3qk\" name=\"Spiral_Navigation_Step\">\n      <bpmn:incoming>Flow_1nefhcf</bpmn:incoming>\n      <bpmn:outgoing>Flow_0s8nmup</bpmn:outgoing>\n      <bpmn:property id=\"Property_0aiehc0\" name=\"__targetRef_placeholder\" />\n      <bpmn:dataInputAssociation id=\"DataInputAssociation_1d2rpvb\">\n        <bpmn:sourceRef>DataObjectReference_046ydzs</bpmn:sourceRef>\n        <bpmn:targetRef>Property_0aiehc0</bpmn:targetRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"DataOutputAssociation_16apb37\">\n        <bpmn:targetRef>DataObjectReference_19e0n2d</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:scriptTask>\n    <bpmn:sequenceFlow id=\"Flow_08rzk0i\" sourceRef=\"Gateway_072gr8o\" targetRef=\"Activity_0bntbkg\" />\n    <bpmn:scriptTask id=\"Activity_0bntbkg\" name=\"Color_Detection\">\n      <bpmn:incoming>Flow_08rzk0i</bpmn:incoming>\n      <bpmn:outgoing>Flow_15w4dk6</bpmn:outgoing>\n      <bpmn:property id=\"Property_161qcwu\" name=\"__targetRef_placeholder\" />\n      <bpmn:dataInputAssociation id=\"DataInputAssociation_0iyptrg\">\n        <bpmn:sourceRef>DataObjectReference_19e0n2d</bpmn:sourceRef>\n        <bpmn:targetRef>Property_161qcwu</bpmn:targetRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"DataOutputAssociation_0f6l4an\">\n        <bpmn:targetRef>DataObjectReference_0a8dq04</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:scriptTask>\n    <bpmn:parallelGateway id=\"Gateway_0dwdsjm\">\n      <bpmn:incoming>Flow_0s8nmup</bpmn:incoming>\n      <bpmn:incoming>Flow_15w4dk6</bpmn:incoming>\n      <bpmn:outgoing>Flow_0pbx0px</bpmn:outgoing>\n    </bpmn:parallelGateway>\n    <bpmn:sequenceFlow id=\"Flow_0s8nmup\" sourceRef=\"Activity_0q3o3qk\" targetRef=\"Gateway_0dwdsjm\" />\n    <bpmn:sequenceFlow id=\"Flow_15w4dk6\" sourceRef=\"Activity_0bntbkg\" targetRef=\"Gateway_0dwdsjm\" />\n    <bpmn:dataObjectReference id=\"DataObjectReference_0a8dq04\" name=\"dataDetection\" dataObjectRef=\"DataObject_09n49md\">\n      <bpmn:extensionElements>\n        <camunda:properties>\n          <camunda:property name=\"pos\" value=\"Positions\" />\n        </camunda:properties>\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n    <bpmn:dataObject id=\"DataObject_09n49md\" />\n    <bpmn:sequenceFlow id=\"Flow_0pbx0px\" sourceRef=\"Gateway_0dwdsjm\" targetRef=\"Activity_0ccanov\" />\n    <bpmn:scriptTask id=\"Activity_0ccanov\" name=\"Filter_Discovered_Area\">\n      <bpmn:incoming>Flow_0pbx0px</bpmn:incoming>\n      <bpmn:outgoing>Flow_1crbevj</bpmn:outgoing>\n      <bpmn:property id=\"Property_0r28wt6\" name=\"__targetRef_placeholder\" />\n      <bpmn:dataInputAssociation id=\"DataInputAssociation_0e3bb